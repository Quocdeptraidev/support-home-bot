# ============================================
# Mây Homestay Support Bot
# Copy to .env and replace every required value.
# Never commit .env.
# ============================================

# --- Application ---
APP_NAME=may-homestay-support-bot
APP_ENV=development
APP_DEBUG=true
LOG_LEVEL=INFO
HOST=0.0.0.0
PORT=8000
APP_TIMEZONE=Asia/Ho_Chi_Minh

# --- Ngrok (Local Tunnel) ---
# Get your authtoken from https://dashboard.ngrok.com
NGROK_AUTHTOKEN=
# Set your static domain from ngrok dashboard to keep webhook URL persistent
NGROK_DOMAIN=

# --- PostgreSQL ---
POSTGRES_DB=homestay_support
POSTGRES_USER=homestay
POSTGRES_PASSWORD=change_me
DATABASE_URL=postgresql+asyncpg://homestay:change_me@db:5432/homestay_support

# --- Redis ---
REDIS_URL=redis://redis:6379/0
REDIS_IDEMPOTENCY_TTL_SECONDS=86400

# --- Facebook Messenger ---
FB_PAGE_ACCESS_TOKEN=
FB_APP_SECRET=
FB_VERIFY_TOKEN=
# Set this to the Graph API version enabled for your Meta app, for example vXX.X.
FB_API_VERSION=
FB_GRAPH_BASE_URL=https://graph.facebook.com
FB_REQUEST_TIMEOUT_SECONDS=10

# --- OpenAI ---
OPENAI_API_KEY=
# Choose a model available to your OpenAI project. Keep model IDs out of source code.
OPENAI_MODEL=
OPENAI_CLASSIFICATION_MODEL=
OPENAI_RESPONSE_MODEL=
OPENAI_MAX_OUTPUT_TOKENS=500
OPENAI_REQUEST_TIMEOUT_SECONDS=30
AI_SAFETY_CHECK_ENABLED=true
AI_MAX_CONVERSATION_HISTORY=10
AI_ESCALATION_CONFIDENCE_THRESHOLD=0.65

# --- Telegram escalation ---
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
TELEGRAM_API_BASE_URL=https://api.telegram.org
TELEGRAM_REQUEST_TIMEOUT_SECONDS=10

# --- Rate limiting ---
FB_API_RATE_LIMIT=200
FB_API_RATE_WINDOW_SECONDS=3600

# --- Optional admin, reserved for a later phase ---
ADMIN_USERNAME=
ADMIN_PASSWORD=
